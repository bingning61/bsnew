{
  "project_name": "基于YOLO视觉感知与中心偏差控制的ROS1焊缝跟踪机器人系统",
  "project_goal": "以相机图像中的焊缝目标检测结果为输入，通过检测框中心位置表征和中心偏差控制，生成cmd_vel并驱动底盘完成焊缝跟踪，同时在检测失效时安全停机。",
  "repo_layout": {
    "repo_root": "bsnew/",
    "ros_workspace_root": "catkin_ws/",
    "ros_packages_root": "catkin_ws/src/",
    "yolo_module_root": "yolo/",
    "reference_media": [
      "原视频.mp4",
      "识别视频.mp4"
    ],
    "thesis_handoff_root": "thesis_handoff/"
  },
  "ros_workspace": "catkin_ws",
  "ros_packages": [
