    }
  ],
  "yolo_module": {
    "path": "yolo/",
    "runtime_entry": "catkin_ws/src/robot_vision/scripts/yolo_seam_detector.py",
    "runtime_backend": "本地ultralytics源码树",
    "local_ultralytics_present": true,
    "weight_file_required": true,
    "weight_file_in_repo": false,
    "known_example_weight_path": "../yolo/runs/train/exp17/weights/best.pt",
    "training_scripts_present": [
      "yolo/train.py",
