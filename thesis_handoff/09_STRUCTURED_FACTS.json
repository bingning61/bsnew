    },
    {
      "path": "catkin_ws/src/robot_vision/launch/line_follow.launch",
      "role": "旧版HSV线跟踪入口",
      "status": "code_confirmed"
    },
    {
      "path": "catkin_ws/src/robot_vision/launch/robot_camera.launch",
      "role": "真实相机输入入口",
      "status": "code_confirmed"
    },
    {
      "path": "catkin_ws/src/base_control/launch/base_control.launch",
      "role": "底盘接口启动入口",
      "status": "code_confirmed"
    },
    {
      "path": "catkin_ws/src/nanoomni_description/launch/simulation.launch",
      "role": "Gazebo模型仿真支撑入口",
      "status": "code_confirmed"
    },
    {
      "path": "catkin_ws/src/robot_simulation/launch/simulation_one_robot.launch",
      "role": "Stage二维仿真支撑入口",
      "status": "code_confirmed"
    }
  ],
  "config_files": [
    {
      "path": "catkin_ws/src/robot_vision/config/line_hsv.cfg",
      "role": "旧版HSV阈值动态配置"
    },
    {
      "path": "catkin_ws/src/robot_vision/config/csi72.yaml",
      "role": "相机标定文件"
    },
    {
      "path": "catkin_ws/src/robot_vision/config/astrapro.yaml",
      "role": "相机标定文件"
    },
    {
      "path": "catkin_ws/src/nanoomni_description/config/joint_names_nanoomni_description.yaml",
      "role": "机器人描述支撑配置"
    }
  ],
  "nodes": [
    {
      "name": "uvc_camera",
      "package": "uvc_camera",
      "entry": "catkin_ws/src/robot_vision/launch/robot_camera.launch",
      "interpreter": "native_ros_node",
      "inputs": [
        "camera device"
      ],
      "outputs": [
        "/image_raw",
        "camera_info"
      ],
      "role": "真实图像输入源"
    },
    {
      "name": "fake_camera",
      "package": "robot_vision",
      "entry": "catkin_ws/src/robot_vision/scripts/fake_camera.py",
      "interpreter": "python2_style",
      "inputs": [
        "image_path parameter"
      ],
      "outputs": [
        "/image_raw"
      ],
      "role": "静态图片调试图像源"
    },
    {
      "name": "yolo_seam_detector",
      "package": "robot_vision",
      "entry": "catkin_ws/src/robot_vision/scripts/yolo_seam_detector.py",
      "interpreter": "python3",
      "inputs": [
        "/image_raw"
      ],
      "outputs": [
        "/seam_center",
        "/result_image"
      ],
      "role": "焊缝目标感知与位置表征"
    },
    {
      "name": "linefollow",
      "package": "robot_vision",
      "entry": "catkin_ws/src/robot_vision/scripts/line_detector.py",
      "interpreter": "python2_style",
      "inputs": [
        "/seam_center or /image_raw"
      ],
      "outputs": [
        "cmd_vel",
        "/mask_image",
        "/result_image"
      ],
      "role": "偏差控制与速度输出"
    },
    {
      "name": "base_control",
      "package": "base_control",
      "entry": "catkin_ws/src/base_control/script/base_control.py",
      "interpreter": "python2_style",
      "inputs": [
        "cmd_vel"
      ],
      "outputs": [
        "serial chassis protocol",
        "odom",
        "battery",
        "imu (optional)",
        "sonar_* (optional)"
      ],
      "role": "底盘执行接口"
    }
  ],
  "topics": [
    {
      "name": "/image_raw",
      "type": "sensor_msgs/Image",
      "producer": [
        "uvc_camera",
        "fake_camera"
      ],
      "consumer": [
        "yolo_seam_detector",
        "legacy line_detector HSV mode"
      ],
      "role": "图像输入"
    },
    {
      "name": "/seam_center",
      "type": "geometry_msgs/Point",
      "producer": [
        "yolo_seam_detector"
      ],
      "consumer": [
        "linefollow"
      ],
      "role": "目标中心位置表征接口"
    },
    {
      "name": "cmd_vel",
      "type": "geometry_msgs/Twist",
      "producer": [
        "linefollow"
      ],
      "consumer": [
        "base_control"
      ],
      "role": "运动控制输出"
    },
    {
      "name": "/result_image",
      "type": "sensor_msgs/Image",
      "producer": [
        "yolo_seam_detector"
      ],
      "consumer": [
        "debug tools"
      ],
      "role": "识别结果可视化"
    },
    {
      "name": "odom",
      "type": "nav_msgs/Odometry",
      "producer": [
        "base_control"
      ],
      "consumer": [
        "other robot system modules"
      ],
      "role": "底盘反馈"
    }
  ],
  "main_data_flow": [
    "真实相机或fake_camera向/image_raw提供图像。",
    "yolo_seam_detector订阅/image_raw并执行YOLO推理。",
    "系统在候选框中选取最佳检测框。",
    "系统计算bbox_center_x并把它编码为/seam_center消息。",
    "line_detector在外部中心点模式下订阅/seam_center。",
    "line_detector把图像中心与目标中心之间的偏差映射为cmd_vel。",
    "base_control订阅cmd_vel并将其编码为串口协议发送给底盘。",
    "底盘执行后改变下一帧图像中的目标位置，从而形成闭环。"
  ],
  "core_methods": [
    {
      "name": "基于YOLO检测的焊缝目标感知方法",
      "problem": "在图像中识别焊缝目标区域",
      "summary": "利用YOLO推理输出候选框，并选取最优目标框作为当前焊缝目标。"
    },
    {
      "name": "基于检测框中心的目标位置表征方法",
      "problem": "把复杂视觉结果转换成控制器可直接使用的量",
      "summary": "以检测框中心横坐标和图像宽度构造轻量消息接口。"
    },
    {
      "name": "基于图像中心参照的偏差构建方法",
      "problem": "建立目标位置与期望位置之间的误差关系",
      "summary": "以图像中心为参考位置，构造目标中心偏差。"
    },
    {
      "name": "基于归一化中心偏差的焊缝跟踪控制方法",
      "problem": "将偏差映射为线速度和角速度",
      "summary": "复用原twist_calculate控制律，输出cmd_vel。"
    },
    {
      "name": "基于转向强度约束的速度协同调节方法",
      "problem": "在纠偏时平衡前进效率与稳定性",
      "summary": "根据角速度大小分段调节linear.x。"
    },
    {
      "name": "基于ROS1话题解耦的感知到控制闭环实现方法",
      "problem": "在ROS1中组织完整视觉闭环",
      "summary": "通过/image_raw、/seam_center、cmd_vel等标准话题实现模块解耦。"
    },
    {
      "name": "基于有效性标志与超时监测的异常安全处理方法",
      "problem": "在检测失效时防止机器人继续盲行",
      "summary": "无检测或超时时发布零速度，并依赖底盘断联停机机制。"
    }
  ],
  "core_principles": [
    "只提取对控制有直接意义的目标中心横坐标，而不是把完整检测框交给控制器。",
    "以图像中心作为期望位置，用目标中心与图像中心的差值表示横向偏差。",
    "在保留原稳定控制律的前提下，通过外部中心点接口完成焊缝任务迁移。",
    "通过ROS1话题把感知层、控制层和执行层解耦。",
    "优先采用简单、可解释、低风险的工程方法，而不是引入复杂高阶算法。"
  ],
  "control_logic": {
    "position_representation": {
      "image_center_x": "image_width / 2.0",
      "target_center_x": "(x1 + x2) / 2.0"
    },
    "error_forms": [
      "e_px = target_center_x - image_center_x",
      "e_ctrl = image_center_x - target_center_x"
    ],
    "straight_condition": "0.95 < target_center_x / image_center_x < 1.05",
    "angular_velocity": "angular_z = ((image_center_x - target_center_x) / image_center_x) / 2.0 = (image_center_x - target_center_x) / image_width",
    "linear_velocity": "if straight then 0.2 else if abs(angular_z) < 0.2 then 0.2 - angular_z / 2.0 else 0.1",
    "unused_components": [
      "linear.y fixed to 0",
      "linear.z fixed to 0",
      "angular.x fixed to 0",
      "angular.y fixed to 0"
    ],
    "stop_logic": [
      "invalid center -> publish zero Twist",
      "external center timeout -> publish zero Twist"
    ]
  },
  "integration_logic": {
    "strategy": "兼容式适配方案",
    "summary": "不重写原控制器，而是新增YOLO前端和外部中心点输入接口，使检测框中心替代旧线中心。",
    "primary_launch": "catkin_ws/src/robot_vision/launch/seam_tracking.launch",
    "preserved_controller": "catkin_ws/src/robot_vision/scripts/line_detector.py::twist_calculate",
    "adapter_interface": "geometry_msgs/Point over /seam_center",
    "evidence_commit": "208353c Add seam tracking integration"
  },
