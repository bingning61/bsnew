        "catkin_ws/src/robot_simulation/launch/simulation_one_robot_with_map.launch"
      ]
    },
    {
      "name": "robot_navigation",
      "role": "雷达导航与定位配套包",
      "main_runtime_path": false,
      "key_files": [
        "catkin_ws/src/robot_navigation/launch/robot_navigation.launch",
        "catkin_ws/src/robot_navigation/launch/lidar.launch",
        "catkin_ws/src/robot_navigation/launch/move_base.launch"
      ]
    },
    {
      "name": "rplidar_ros",
      "role": "雷达驱动支撑包",
      "main_runtime_path": false
    },
    {
      "name": "nvilidar_ros",
      "role": "雷达驱动支撑包",
      "main_runtime_path": false
    },
    {
      "name": "sc_mini",
      "role": "雷达驱动支撑包",
      "main_runtime_path": false
    },
    {
      "name": "bingda_tutorials",
      "role": "教学/历史材料包",
